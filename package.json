{
  "name": "bnote-settings",
  "version": "2.1.0",
  "author": {
    "name": "Theotime Berthod",
    "email": "theo.blind@yahoo.com"
  },
  "description": "Interface to manage the B.note settings",
  "repository": {
    "directory": "./",
    "type": "git",
    "url": "https://github.com/theotime2005/bnote-settings"
  },
  "homepage": "https://manage-bnote.vercel.app",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "electron": "electron .",
    "pack": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:windows": "electron-builder --windows",
    "build:all": "electron-builder --mac --windows"
  },
  "main": "electron.js",
  "build": {
    "appId": "com.theotime.bnote",
    "productName": "BNoteSettings",
    "files": [
      "dist/**/*",
      "electron.js"
    ],
    "mac": {
      "category": "public.app-category.utility",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist/build"
    },
    "artifactName": "bnote-settings.${ext}"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.29",
    "vue-i18n": "^10.0.0",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.8.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.45",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.10",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  }
}
