# This file is the minimum environment variable for the project.
# Type string
# URL to send api messages
# LOG_API_URL=""

# Google site verification
GOOGLE_SITE_VERIFICATION=

# Server environment variables (used by server/config.js)
# MODE: development | production | test
MODE=development

# Mailing configuration
# Enable sending emails (true/false)
MAILING_ENABLED=false
# Use Ethereal test account when enabled (true/false)
MAILING_TEST_ACCOUNT_ENABLED=true
# SMTP host (e.g. smtp.gmail.com)
MAILING_HOST=smtp.example.com
# SMTP port (numeric)
MAILING_PORT=587
# Use TLS/SSL (true/false)
MAILING_SECURE=false
# SMTP authentication
MAILING_USER=your@example.com
MAILING_PASSWORD=yourpassword

# =================
# Flags
# This section is only used in local development
# Flags can be used in any environment.
# Local flags are used when USE_VERCEL_FLAGS is false.
# =================
# Flag system
# Use vercel flags or local flags
USE_VERCEL_FLAGS=false

# Local flags (used when USE_VERCEL_FLAGS is false)
